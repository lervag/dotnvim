{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "lua/?.lua",
      "lua/?/init.lua",
      "?/lua/?.lua",
      "?/lua/?/init.lua"
    ]
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME",
      "$HOME/.local/share/nvim/site/pack/core/opt/mini.icons",
      "$HOME/.local/share/nvim/site/pack/core/opt/mini.notify",
      "$HOME/.local/share/nvim/site/pack/core/opt/mini.snippets",
      "$HOME/.local/share/nvim/site/pack/core/opt/nvim-lspconfig",
      "$HOME/.local/share/nvim/site/pack/core/opt/lazy.nvim",
      "$HOME/.local/share/nvim/site/pack/core/opt/snacks.nvim"
    ]
  },
  "diagnostics.globals": ["MiniSnippets"]
}
